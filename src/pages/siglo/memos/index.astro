---
import Dashboard from "@/layouts/Dashboard.astro";
import FileUpload from "@ui/FileUpload";
import SearchIcon from "@ui/icons/SearchIcon";
---

<Dashboard>
    <div class="space-y-5">
        <div class="space-y-2">
            <h1 class="font-semibold text-2xl text-text">Memofichas</h1>
            <p class="text-sm text-text2">Documentos de soportes adjuntados</p>
        </div>

        <div class="bg-white rounded-[14px] p-5 space-y-5">
            <h2 class="text-text font-bold text-xl">Documentos de soportes</h2>
            <FileUpload />
            <div class="p-5 rounded-2xl border border-[#DEE5ED] space-y-5">
                <h3 class="font-semibold">Listado de documentos</h3>
                <div
                    class="h-10 w-[200px] rounded-lg bg-[#F5F7F9] border border-[#DEE5ED] flex"
                >
                    <input
                        class="outline-none px-4 w-[160px]"
                        type="text"
                        placeholder="Buscar..."
                        name=""
                        id=""
                    />
                    <div
                        class="size-10 border-l border-[#DEE5ED] grid place-items-center"
                    >
                        <SearchIcon className="text-[#7C93B5]" />
                    </div>
                </div>
                <table class=""></table>
            </div>
        </div>
    </div>
</Dashboard>
